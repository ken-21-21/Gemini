{
  "name": "fsrs-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p . && mkdir -p dist/db && cp src/db/schema.sql dist/db/schema.sql",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "kuromoji": "^0.1.2",
    "multer": "^2.0.1",
    "pdf-parse": "^1.1.1",
    "sql.js": "^1.12.0",
    "ts-fsrs": "^4.6.0",
    "wink-eng-lite-web-model": "^1.8.0",
    "wink-nlp": "^2.3.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/kuromoji": "^0.1.3",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/sql.js": "^1.4.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
